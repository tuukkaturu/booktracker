# Gemini API key — get yours free at https://aistudio.google.com/app/apikey
# This file stays on your machine and is never committed to git.
GEMINI_API_KEY=

# Optional: change the port the API server listens on (default: 3001)
# PORT=3001

# Optional: require clients to send a shared API token in x-api-token.
# Set this on Railway as API_SHARED_TOKEN.
API_SHARED_TOKEN=

# Netlify Function secure proxy (recommended):
# - RAILWAY_API_URL (set in Netlify): e.g. https://your-app.up.railway.app
# - RAILWAY_API_TOKEN (set in Netlify): same value as API_SHARED_TOKEN on Railway
# Keep these server-side in Netlify env, never as VITE_* vars.
RAILWAY_API_URL=
RAILWAY_API_TOKEN=
